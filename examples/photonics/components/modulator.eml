// modulator.eml -- P1 PHOTONIC COMPONENT LIBRARY (4/8)
//
// Electro-optic modulator (Pockels effect).  The applied
// electric field E modulates the refractive index linearly:
//
//   delta_n = (1/2) * n^3 * r_eff * E
//
//   n         baseline refractive index
//   r_eff     effective Pockels coefficient (m/V)
//   E         applied modulating field (V/m)
//
// Chain order 0 (algebraic).
//
// @verify obligations:
//   1. Zero applied field -> zero index change (the
//      "modulator off" boundary condition).
//   2. Index change is linear in applied field -- witness
//      captured as the algebraic identity that drives the
//      drive-voltage to optical-phase calibration in P3.

module modulator;

const N_LINBO3: Real = 2.21          // LiNbO3 baseline at 1.55um
const R_EFF_LINBO3: Real = 30.8e-12  // m/V, r33 for LiNbO3

// Pockels-effect index modulation.
fn delta_n(n: Real, r_eff: Real, e_field: Real) -> Real
    where chain_order <= 0
{
    0.5 * n * n * n * r_eff * e_field
}

// At zero applied field the index change vanishes -- the
// modulator is in its "off" state.  Carries the bias-point
// witness used by the controller code.
@verify(lean, theorem = "modulator_off_at_zero_field")
fn delta_n_at_zero_field(n: Real, r_eff: Real) -> Real
    where chain_order <= 0
    ensures (result == 0.0)
{
    0.5 * n * n * n * r_eff * 0.0
}

// The Pockels coefficient is strictly positive in any practical
// EO material -- the witness used by the calibration loop to
// guarantee monotone control authority.
@verify(lean, theorem = "modulator_pockels_positive")
fn pockels_positive(r_eff: Real) -> Real
    where chain_order <= 0
    requires (r_eff > 0.0)
    ensures (result > 0.0)
{
    r_eff
}
