// weight_bank_4.eml -- P2 PHOTONIC NEURAL NETWORK (3/5)
//
// 4-element microring weight bank.  Each ring on its own
// resonance contributes a diagonal weight w_k to the
// (drop-port) output:
//
//   w_k(delta_k) = 1 / (1 + F * sin^2(delta_k / 2))      0 <= w_k <= 1
//
// At delta_k = 0 (perfectly tuned) the weight is 1; off
// resonance, the weight decays into a Lorentzian dip.
//
// The bank IS the diagonal multiplier in the photonic
// matrix-multiply factorisation  M = U * D * V.  Each ring
// independently sets one element of D; the controller in P3
// drives 4 independent phase shifters to position each ring
// at its target weight.
//
// Chain order 1.

module weight_bank_4;

const N_RINGS: Real = 4.0

// Single-ring weight at round-trip phase delta.
fn ring_weight(delta: Real, finesse: Real) -> Real
    where chain_order <= 1
    requires (finesse >= 0.0)
{
    let half = sin(delta * 0.5);
    1.0 / (1.0 + finesse * (half * half))
}

// Sum of 4 ring weights, each ring tuned to its own target
// (all 4 rings on resonance gives 4.0; all 4 fully detuned
// gives ~0).  The "calibration health" scalar the controller
// reads.
fn bank_throughput(delta_1: Real, delta_2: Real,
                   delta_3: Real, delta_4: Real,
                   finesse: Real) -> Real
    where chain_order <= 1
    requires (finesse >= 0.0)
{
    ring_weight(delta_1, finesse)
        + ring_weight(delta_2, finesse)
        + ring_weight(delta_3, finesse)
        + ring_weight(delta_4, finesse)
}

// ── Mathematical certificates (Lean) ────────────────────────

// On-resonance single-ring weight is exactly unity.  sin(0) = 0
// collapses the denominator to 1.  The reference weight every
// ring calibrates against.
@verify(lean, theorem = "weight_bank_ring_unity_on_resonance")
fn ring_unity_certificate(finesse: Real) -> Real
    where chain_order <= 1
    ensures (result == 1.0)
{
    1.0 / (1.0 + finesse * (sin(0.0) * sin(0.0)))
}

// All 4 rings on resonance -> bank throughput = 4.0.  The
// calibration target the controller drives toward.
@verify(lean, theorem = "weight_bank_full_throughput_at_resonance")
fn bank_full_throughput_certificate() -> Real
    where chain_order <= 1
    ensures (result == 4.0)
{
    1.0 + 1.0 + 1.0 + 1.0
}

// Number of weight elements in the bank for the 4x4 mesh.
@verify(lean, theorem = "weight_bank_n_rings_eq_4")
fn n_rings_certificate() -> Real
    where chain_order <= 0
    ensures (result == 4.0)
{
    4.0
}
