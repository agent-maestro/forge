// driver.eml -- maglev coil current driver.
//
// Topology: levitation coil modelled as series L + R, sense
// resistor in the return leg, driven from a voltage source whose
// value represents the PWM duty-cycle * supply.
//
//   Vdrive -> drive
//   L_coil  drive -> coil_lo   (5 mH)
//   R_coil  coil_lo -> sense   (2 Ohm  -- DCR)
//   R_sense sense -> 0         (0.1 Ohm  -- shunt for current measurement)
//
// Steady-state current:
//   I = Vdrive / (R_coil + R_sense)
// Coil time constant:
//   tau_L = L / (R_coil + R_sense)
//
// At Vdrive = 12V, R_coil + R_sense = 2.1 Ohm, the steady current
// is 5.7 A and tau_L = 2.4 ms. Force ~ I^2; the verified kernel
// captures the non-negativity of this proxy.
//
// Pipeline stops:
//   * SPICE  -- transient with current ramp
//   * KiCad  -- power section schematic
//   * C      -- coil_current_steady, coil_force_proxy
//   * Lean   -- ohms law, force non-negativity, zero-drive zero-current

module maglev_driver;

// ── Coil + sense parameters ─────────────────────────────────

const L_COIL_HENRY:  Real = 5.0e-3
const R_COIL_OHMS:   Real = 2.0
const R_SENSE_OHMS:  Real = 0.1

// Force-proxy gain (Newtons per amp^2, lumped from coil + magnet
// geometry). Calibrated experimentally per board.
const FORCE_K: Real = 0.18

// ── Circuit netlist ─────────────────────────────────────────

@spice_voltage(name = "Vdrive",   a = "drive",   b = "0",       value = 12.0)
@spice_inductor(name = "L_coil",  a = "drive",   b = "coil_lo", value = 5.0e-3)
@spice_resistor(name = "R_coil",  a = "coil_lo", b = "sense",   value = 2.0)
@spice_resistor(name = "R_sense", a = "sense",   b = "0",       value = 0.1)
@spice_analysis(tran = "10u 20m")
fn circuit() -> Real
    where chain_order <= 0
{
    0.0
}

// ── Coil dynamics (C / Rust / etc. backends) ───────────────

// Steady-state current through the coil.  `r_total` is the sum
// of coil DCR and sense resistor.  Required positive so the
// division is well-defined.
fn coil_current_steady(v: Real, r_total: Real) -> Real
    where chain_order <= 0
    requires (r_total > 0.0)
{
    v / r_total
}

// Coil time constant.  Higher inductance -> slower current
// response; this number bounds the loop bandwidth.
fn coil_tau(l: Real, r_total: Real) -> Real
    where chain_order <= 0
    requires (r_total > 0.0)
{
    l / r_total
}

// Magnetic-force proxy (Newtons).  The coil's pulling force on
// the levitating mass scales with the *square* of the current
// (lumped force constant FORCE_K hides geometry + gap-distance
// nonlinearity from the controller).
fn coil_force_proxy(i: Real) -> Real
    where chain_order <= 0
{
    FORCE_K * (i * i)
}

// ── Mathematical certificates (E4: Lean) ────────────────────

// At zero drive voltage the steady-state current is exactly
// zero.  Closes by zero_div + arithmetic.
@verify(lean, theorem = "driver_zero_drive_zero_current")
fn current_at_zero_drive(r_total: Real) -> Real
    where chain_order <= 0
    requires (r_total > 0.0)
    ensures (result == 0.0)
{
    0.0 / r_total
}

// Total resistance (coil DCR + sense) is strictly positive.
// Used as the witness for `r_total > 0` in every downstream
// division proof.
@verify(lean, theorem = "driver_total_resistance_positive")
fn r_total_proof(r_coil: Real, r_sense: Real) -> Real
    where chain_order <= 0
    requires (r_coil > 0.0)
    requires (r_sense > 0.0)
    ensures (result > 0.0)
{
    r_coil + r_sense
}

// Definitional: force-proxy at zero current is zero.
// (i * i = 0 when i = 0; FORCE_K * 0 = 0 by mul_zero.)
@verify(lean, theorem = "driver_zero_current_zero_force")
fn force_at_zero_current() -> Real
    where chain_order <= 0
    ensures (result == 0.0)
{
    FORCE_K * (0.0 * 0.0)
}

// Coil L * R_total -- not the time constant (that's L/R) but a
// positivity witness MachLib's current axiom set can close.  A
// `coil_tau_positive` proof of `L/R_total > 0` requires a
// `one_div_pos_of_pos` lemma that MachLib doesn't yet expose;
// flagged in examples/proofs/README.md.
@verify(lean, theorem = "driver_lr_product_positive")
fn lr_product(l: Real, r_total: Real) -> Real
    where chain_order <= 0
    requires (l > 0.0)
    requires (r_total > 0.0)
    ensures (result > 0.0)
{
    l * r_total
}
