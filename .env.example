# Environment variables consumed by Forge tools.
#
# `eml-compile` itself runs without env vars. The variables below
# are only needed by specific subsystems — copy to `.env` and fill
# in the ones your workflow actually uses.

# Path to a local MachLib checkout. Required by:
#   - software/verification/lean/discovered_emit.py (Lean
#     verification batch sweep)
#   - software/backends/solidity_audit.py (audit harness)
# Default: looked up via `git rev-parse --show-toplevel ../machlib`
# if unset, but explicit is better. Get MachLib from
# https://github.com/agent-maestro/machlib.
MACHLIB_ROOT=

# Pro-tier license token. Unlocks the 20 paid backends (GPU
# shaders, FPGA RTL, safety-critical, Coq, Isabelle/HOL,
# Solidity, Luau, GDScript). The 13 free-tier targets (Rust, C,
# Python, WebAssembly, Lean 4, etc.) work with no license.
# Get a token at https://monogateforge.com/get-started.
MONOGATE_LICENSE=

# Path to the compiled Plonky2 ZK runner binary. Required by the
# zkproof backend (`--target zkproof`). Build via
# `cargo build --release` in `lang/zkproof/plonky2_backend/` and
# point this at the resulting binary (`target/release/plonky2_runner`).
MONOGATE_ZK_BIN=
