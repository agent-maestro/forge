{
  "name": "monogate-forge-vscode",
  "displayName": "Monogate Forge",
  "description": "EML-lang for VS Code. Free: syntax + snippets + completion + outline. With Forge CLI: LSP (errors-as-you-type, hover, cross-file goto-def + references + rename, format, workspace symbol search), builtin docs, inline profiling, FPGA status, 32-target compile.",
  "version": "0.8.1",
  "publisher": "Monogate",
  "license": "MIT",
  "homepage": "https://monogate.dev/learn/eml",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-maestro/forge.git",
    "directory": "tools/ide/vscode"
  },
  "bugs": {
    "url": "https://github.com/agent-maestro/forge/issues"
  },
  "keywords": ["eml", "monogate", "forge", "verified-math", "lean",
               "verilog", "vhdl", "fpga", "verification"],
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Linters", "Formatters"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:eml"
  ],
  "contributes": {
    "languages": [{
      "id": "eml",
      "aliases": ["EML", "eml-lang"],
      "extensions": [".eml"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "eml",
      "scopeName": "source.eml",
      "path": "./syntaxes/eml.tmLanguage.json"
    }],
    "snippets": [{
      "language": "eml",
      "path": "./snippets/eml.json"
    }],
    "commands": [
      { "command": "monogate-forge.profile",              "title": "Refresh profile lenses",      "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.pick",         "title": "Compile to...",               "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.c",            "title": "Compile to C",                "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.cpp",          "title": "Compile to C++",              "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.rust",         "title": "Compile to Rust",             "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.go",           "title": "Compile to Go",               "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.java",         "title": "Compile to Java",             "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.kotlin",       "title": "Compile to Kotlin",           "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.python",       "title": "Compile to Python",           "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.matlab",       "title": "Compile to MATLAB",           "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.llvm",         "title": "Compile to LLVM IR",          "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.wasm",         "title": "Compile to WebAssembly",      "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.verilog",      "title": "Compile to Verilog",          "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.systemverilog","title": "Compile to SystemVerilog",    "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.vhdl",         "title": "Compile to VHDL",             "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.chisel",       "title": "Compile to Chisel",           "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.ada",          "title": "Compile to Ada / SPARK",      "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.autosar",      "title": "Compile to AUTOSAR",          "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.aadl",         "title": "Compile to AADL",             "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.ros2",         "title": "Compile to ROS 2",            "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.lean",         "title": "Compile to Lean 4",           "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.coq",          "title": "Compile to Coq",              "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.isabelle",     "title": "Compile to Isabelle/HOL",     "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.solidity",     "title": "Compile to Solidity",         "category": "Monogate Forge" },
      { "command": "monogate-forge.compile.all",          "title": "Compile to all targets (your tier)", "category": "Monogate Forge" }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == eml",
          "command": "monogate-forge.compile.pick",
          "group": "monogate-forge@1"
        },
        {
          "when": "resourceLangId == eml",
          "command": "monogate-forge.compile.all",
          "group": "monogate-forge@2"
        },
        {
          "when": "resourceLangId == eml",
          "command": "monogate-forge.profile",
          "group": "monogate-forge@3"
        }
      ]
    },
    "configuration": {
      "title": "Monogate Forge",
      "properties": {
        "eml.compile.python": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter used to invoke tools/cli/main.py."
        },
        "eml.fpga.target": {
          "type": "string",
          "default": "xilinx.artix7",
          "enum": [
            "xilinx.artix7",
            "lattice.ice40",
            "lattice.ecp5",
            "intel.cyclone10",
            "asic.sky130"
          ],
          "description": "FPGA / ASIC target identifier passed to --fpga-target."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "typescript": "^5"
  }
}
