# Source TypeScript -- only the compiled out/ ships
src/**
tsconfig.json
**/*.ts.map
out/**/*.js.map

# Dev artifacts
.gitignore
.vscode/**
.vscode-test/**
package-lock.json
*.vsix

# node_modules: vsce ships production deps automatically. Keep
# the development-only chunks out of the bundle.
node_modules/**/*.md
node_modules/**/*.ts
node_modules/**/*.map
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/.bin/**
node_modules/.cache/**
