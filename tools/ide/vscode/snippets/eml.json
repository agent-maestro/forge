{
  "module declaration": {
    "prefix": "module",
    "body": ["module ${1:my_module};", "", "$0"],
    "description": "Module declaration at the top of the file"
  },
  "use stdlib (whole module)": {
    "prefix": "usestdlib",
    "body": ["use stdlib::${1|math,ml,signal,linalg,control,constants|};"],
    "description": "Pull in a whole stdlib module"
  },
  "use stdlib (selective)": {
    "prefix": "usestdselect",
    "body": [
      "use stdlib::${1|math,ml,signal,linalg,control|}::{${2:lerp}};"
    ],
    "description": "Selective import of one stdlib symbol"
  },
  "function with @verify contract": {
    "prefix": "fnverify",
    "body": [
      "@verify(lean, theorem = \"${1:my_theorem}\")",
      "fn ${2:my_fn}(${3:x: Real}) -> ${4:Real}",
      "    where chain_order <= ${5:1}",
      "    requires (${6:x > 0.0})",
      "    ensures  (${7:result > 0.0})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Function with @verify Hoare contract for Lean export"
  },
  "function with chain_order bound": {
    "prefix": "fnchain",
    "body": [
      "fn ${1:my_fn}(${2:x: Real}) -> ${3:Real}",
      "    where chain_order <= ${4:1}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Function with explicit chain_order constraint"
  },
  "plain function": {
    "prefix": "fn",
    "body": [
      "fn ${1:my_fn}(${2:x: Real}) -> ${3:Real} {",
      "    $0",
      "}"
    ],
    "description": "Plain function declaration"
  },
  "real constant": {
    "prefix": "const",
    "body": ["const ${1:NAME}: ${2:Real} = ${3:0.0};"],
    "description": "Module-level constant"
  },
  "type alias": {
    "prefix": "type",
    "body": ["type ${1:MyType} = ${2:Real};"],
    "description": "Domain type alias"
  },
  "requires precondition": {
    "prefix": "requires",
    "body": ["requires (${1:x > 0.0})"],
    "description": "@verify precondition clause"
  },
  "ensures postcondition": {
    "prefix": "ensures",
    "body": ["ensures  (${1:result > 0.0})"],
    "description": "@verify postcondition clause"
  },
  "@target FPGA": {
    "prefix": "targetfpga",
    "body": ["@target(fpga, latency_cycles = ${1:8}, mac_units = ${2:4})"],
    "description": "FPGA target annotation"
  },
  "@verify Lean": {
    "prefix": "verify",
    "body": ["@verify(lean, theorem = \"${1:my_theorem}\")"],
    "description": "@verify annotation for Lean export"
  },
  "@verify Coq": {
    "prefix": "verifycoq",
    "body": ["@verify(coq, theorem = \"${1:my_theorem}\")"],
    "description": "@verify annotation for Coq export"
  },
  "@verify Isabelle": {
    "prefix": "verifyisabelle",
    "body": ["@verify(isabelle, theorem = \"${1:my_theorem}\")"],
    "description": "@verify annotation for Isabelle/HOL export"
  },
  "let binding": {
    "prefix": "let",
    "body": ["let ${1:x} = ${2:expr};"],
    "description": "Local let binding"
  },
  "if-else": {
    "prefix": "if",
    "body": [
      "if ${1:cond} {",
      "    ${2:then_expr}",
      "} else {",
      "    ${3:else_expr}",
      "}"
    ],
    "description": "If-else expression"
  },
  "gaming: physics step (spring-mass-damper)": {
    "prefix": "fnphysics",
    "body": [
      "@verify(lean, theorem = \"${1:energy_bounded}\")",
      "fn ${2:spring_step}(x: Real, v: Real, dt: Real) -> Real",
      "    where chain_order <= 1",
      "    requires (dt > 0.0)",
      "    ensures  (result == result)",
      "{",
      "    let k = ${3:1.0};",
      "    let damping = ${4:0.05};",
      "    let a = -k * x - damping * v;",
      "    v + a * dt",
      "}"
    ],
    "description": "Gaming physics step with @verify (spring-mass-damper)"
  },
  "gaming: smooth easing curve": {
    "prefix": "fnease",
    "body": [
      "@verify(lean, theorem = \"${1:ease_in_unit_interval}\")",
      "fn ${2:ease_in_out}(t: Real) -> Real",
      "    where chain_order <= 1",
      "    requires (t >= 0.0)",
      "    requires (t <= 1.0)",
      "    ensures  (result >= 0.0)",
      "    ensures  (result <= 1.0)",
      "{",
      "    t * t * (3.0 - 2.0 * t)",
      "}"
    ],
    "description": "Smoothstep easing with [0,1] contract"
  },
  "gaming: PBR Fresnel (Schlick)": {
    "prefix": "fnfresnel",
    "body": [
      "@verify(lean, theorem = \"${1:fresnel_unit_interval}\")",
      "fn ${2:fresnel_schlick}(cos_theta: Real, f0: Real) -> Real",
      "    where chain_order <= 1",
      "    requires (cos_theta >= 0.0)",
      "    requires (cos_theta <= 1.0)",
      "    requires (f0 >= 0.0)",
      "    requires (f0 <= 1.0)",
      "    ensures  (result >= 0.0)",
      "    ensures  (result <= 1.0)",
      "{",
      "    let one_minus_c = 1.0 - cos_theta;",
      "    f0 + (1.0 - f0) * pow(one_minus_c, 5.0)",
      "}"
    ],
    "description": "Schlick Fresnel approximation with @verify"
  },
  "gaming: ease snippet (cubic)": {
    "prefix": "easecubic",
    "body": [
      "fn ${1:ease_in_cubic}(t: Real) -> Real",
      "    where chain_order <= 0",
      "    requires (t >= 0.0)",
      "    requires (t <= 1.0)",
      "    ensures  (result >= 0.0)",
      "    ensures  (result <= 1.0)",
      "{",
      "    t * t * t",
      "}"
    ],
    "description": "Cubic ease-in (no @verify; chain_order = 0)"
  },
  "crypto: constant-time scalar mul (skeleton)": {
    "prefix": "fnconsttime",
    "body": [
      "@verify(lean, theorem = \"${1:constant_time}\")",
      "@target(constant_time)",
      "fn ${2:scalar_mul}(scalar: U256, point: Point) -> Point",
      "    where chain_order <= 1",
      "    ensures  (timing_independent_of(scalar))",
      "{",
      "    $0",
      "}"
    ],
    "description": "Constant-time crypto skeleton with @target(constant_time)"
  },
  "@target multi-platform": {
    "prefix": "targetmulti",
    "body": [
      "@target(${1|fpga,gpu,cpu,constant_time|}, ${2:latency_cycles = 8})"
    ],
    "description": "@target annotation with platform picker"
  },
  "extern fn declaration": {
    "prefix": "extern",
    "body": [
      "extern fn ${1:helper}(${2:x: Real}) -> ${3:Real};"
    ],
    "description": "Forward declaration of an external EML helper"
  }
}
