// abrams_strength.eml -- Abrams' law for concrete compressive strength.
//
// Duff Abrams (1918): the compressive strength of concrete falls
// approximately exponentially with the water/cement ratio:
//
//   f_c = A * exp(-k * (w/c))                         (exponential form)
//   f_c = A_b / pow(B, w/c)                           (Abrams' original)
//
// Both forms are equivalent under k = ln(B). We ship the
// exponential form because it composes cleanly with `pow` lookups
// from concrete-design tables and gives a chain-1 kernel.
//
// Companion kernels: maturity-method strength gain over time
// (Nurse-Saul, time-temperature factor) and the ACI strength-age
// extrapolation. drift_risk LOW under structural-concrete bounds.
//
// Sibling to construction/beam/euler_bernoulli (the deflection
// gate that consumes f_c via E = 4700*sqrt(f_c) for normal-weight
// concrete) and to chemistry/process_control/crystallization
// (the upstream cement-hydration kinetics).

module abrams_strength;

const ZERO:       Real = 0.0
const ONE:        Real = 1.0
const A_MAX:      Real = 200.0       // MPa — generous unconstrained upper
const K_MAX:      Real = 10.0        // typical 1-3 for w/c in 0.3-0.7
const WC_MIN:     Real = 0.2         // workability floor; below = unhydrated
const WC_MAX:     Real = 1.0         // above ~0.8 strength collapses

const M_MAX:      Real = 1.0e4       // maturity index °C-hr cap
const T_MIN_C:    Real = -10.0       // datum lower bound
const T_DATUM:    Real = -10.0       // Nurse-Saul reference temperature

type Strength = Real where chain_order <= 1
type Maturity = Real where chain_order <= 1

// Abrams' exponential strength model. Chain order 1.
@target(fpga, clock_mhz = 250, precision = float64)
@verify(lean, theorem = "abrams_strength_decreases_with_wc")
fn compressive_strength(
    a_intercept: Real, k_decay: Real, water_cement_ratio: Real,
) -> Strength
    where chain_order <= 1
    requires (a_intercept >= 0.0)
    requires (a_intercept <= A_MAX)
    requires (k_decay >= 0.0)
    requires (k_decay <= K_MAX)
    requires (water_cement_ratio >= WC_MIN)
    requires (water_cement_ratio <= WC_MAX)
    ensures  (result >= 0.0)
{
    a_intercept * exp(-k_decay * water_cement_ratio)
}

// Nurse-Saul maturity index M = sum_t (T - T_datum) * dt. We
// expose the per-step contribution (chain 0); the caller sums
// over the curing schedule.
@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "nurse_saul_step_nonneg_above_datum")
fn nurse_saul_step(
    temperature_c: Real, dt_hours: Real,
) -> Maturity
    where chain_order <= 0
    requires (temperature_c >= T_MIN_C)
    requires (temperature_c <= 100.0)
    requires (dt_hours >= 0.0)
    requires (dt_hours <= 24.0)
{
    (temperature_c - T_DATUM) * dt_hours
}

// ACI 209 hyperbolic age-strength gain factor:
//   f_c(t) = f_c(28) * t / (alpha + beta * t)
// Caller supplies f_c(28); we return the multiplier. Chain order 0.
@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "aci_age_strength_factor_in_unit_interval")
fn age_strength_factor(
    age_days: Real, alpha: Real, beta: Real,
) -> Strength
    where chain_order <= 0
    requires (age_days >= 1.0)
    requires (age_days <= 1000.0)
    requires (alpha > 0.0)
    requires (alpha <= 50.0)
    requires (beta > 0.0)
    requires (beta <= 5.0)
    ensures  (result >= 0.0)
{
    age_days / (alpha + beta * age_days)
}
