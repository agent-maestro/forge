// motor_foc.eml -- automotive field-oriented control (FOC) for
// a permanent-magnet synchronous motor (PMSM).
//
// ISO 26262 ASIL-D candidate. The d-axis current loop drives
// torque; the q-axis loop drives flux. Failure of either loop
// can result in unintended motor rotation -- catastrophic for
// EV powertrain.
//
// Pipeline:
//   (i_a, i_b, i_c)  -- 3-phase phase currents from sensors
//   theta            -- rotor electrical angle from encoder
//
//   1. Clarke transform: 3-phase -> alpha/beta (stationary frame)
//   2. Park transform:   alpha/beta -> d/q   (rotor frame)
//   3. PI loops on (i_d, i_q) -> (v_d, v_q)
//   4. Inverse Park: (v_d, v_q) -> (v_alpha, v_beta)
//   5. SVPWM (Space Vector PWM) outputs feed the inverter
//
// All steps proven within actuator limits via @verify(lean).

module motor_foc_automotive;

// ── Imports ──────────────────────────────────────────────────
// `pid` and `saturate` come from stdlib::control.
// `park` and `clarke` come from a sibling file via local::,
// which demonstrates the in-vertical helper-sharing pattern
// (could be imported by a q-axis controller in the same dir).
// The inliner substitutes both stdlib + local bodies before
// the FPGA backend emits Verilog.
use stdlib::control;
use local::three_phase;

// ── Tunings (per-motor; calibrated values) ────────────────────
const Kp_d:      Real = 0.8       // d-axis current-loop P gain
const Ki_d:      Real = 12.0      // d-axis current-loop I gain
const Kp_q:      Real = 0.8       // q-axis current-loop P gain
const Ki_q:      Real = 12.0      // q-axis current-loop I gain
const dt:        Real = 0.0001    // 10 kHz control loop
const V_DC:      Real = 400.0     // DC-bus voltage, V (typical EV)
const V_LIMIT:   Real = 230.94    // = V_DC / sqrt(3), max phase voltage

// `park` and `clarke` are now imported from local::three_phase
// (see the `use` block at the top). Their StableSignal type alias
// arrives with them and is reused below.

// ── Per-axis PI controller (PI is the no-D special case of PID) ──
// Uses stdlib::control::pid with the derivative term zeroed out.
// Constant-folding removes the `Kd * 0.0` and `+ 0.0` introduced
// by that specialisation.
fn pi_step(
    error: Real, integral: Real, Kp: Real, Ki: Real,
) -> StableSignal {
    pid(error, integral, 0.0, Kp, Ki, 0.0)
}

// ── Top-level FOC voltage demand for the d-axis ───────────────
// (q-axis is structurally identical -- same chain order, same
// safety bound. Only one verified for the demo; the second falls
// out by symmetry.)
@target(fpga, clock_mhz = 100, precision = float32)
@verify(lean, theorem = "vd_command_within_inverter_limits")
fn foc_d_axis(
    i_d_setpoint: Real{i | abs(i) < 500.0},   // realistic peak motor current, A
    i_d_measured: Real{i | abs(i) < 500.0},
    i_d_integral: Real{i | abs(i) < 100.0},   // anti-windup limit
) -> Real
    ensures  (abs(result) < V_LIMIT)
{
    let error = i_d_setpoint - i_d_measured;
    let v_d_unclamped = pi_step(error, i_d_integral, Kp_d, Ki_d);
    saturate(v_d_unclamped, V_LIMIT)
}
