// inertia_emulation.eml -- synthetic inertia for inverter-
// dominated grids.
//
// As legacy synchronous generators retire and battery / wind /
// PV inverters take their place, the grid loses physical
// rotating-mass inertia. Synthetic inertia emulates the swing-
// equation response in the inverter control loop:
//
//   delta_p_emul = K_inertia * df/dt + K_droop * (f_meas - f_nominal)
//
// The first term is the inertial (df/dt) component, the second
// is the steady-state droop. The inverter modulates its real-
// power output by delta_p_emul.
//
// Chain order 0. Companion of swing_equation.eml + load_flow.eml.
// IEC 61508 SIL-2 in grid-scale storage applications.

module inertia_emulation;

const K_INERTIA_MIN: Real = 0.0
const K_INERTIA_MAX: Real = 50.0          // s, equivalent inertia const
const K_DROOP_MIN:   Real = 0.0
const K_DROOP_MAX:   Real = 100.0
const F_NOM:         Real = 50.0
const F_MIN:         Real = 45.0
const F_MAX:         Real = 55.0
const DF_DT_MAX:     Real = 5.0           // Hz/s
const POWER_MAX:     Real = 1.0e3         // pu

type EmulatedPower = Real where chain_order <= 0

@target(fpga, clock_mhz = 250, precision = float64)
@verify(lean, theorem = "synthetic_inertia_response_signed")
fn synthetic_power_command(
    df_dt:             Real{x | abs(x) <= DF_DT_MAX},
    frequency_meas:    Real{f | F_MIN <= f && f <= F_MAX},
    frequency_nominal: Real{f | F_MIN <= f && f <= F_MAX},
    k_inertia:         Real{k | K_INERTIA_MIN <= k && k <= K_INERTIA_MAX},
    k_droop:           Real{k | K_DROOP_MIN <= k && k <= K_DROOP_MAX},
) -> EmulatedPower
    where chain_order <= 0
{
    -k_inertia * df_dt - k_droop * (frequency_meas - frequency_nominal)
}

// ROCOF (rate of change of frequency) computed from a finite-
// difference window. Used both as an input to synthetic
// inertia and as a tripping criterion for protection relays.
@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "rocof_zero_at_constant_frequency")
fn rocof_estimate(
    frequency_now:  Real{f | F_MIN <= f && f <= F_MAX},
    frequency_prev: Real{f | F_MIN <= f && f <= F_MAX},
    dt:             Real{t | 0.0 < t && t <= 1.0},
) -> Real
    where chain_order <= 0
{
    (frequency_now - frequency_prev) / dt
}

// Power-headroom limited inertia response: the emulated power
// command cannot exceed the inverter's available headroom in
// either direction. Branch-free clamp.
@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "headroom_limited_within_inverter_capability")
fn headroom_limited_response(
    desired_power: Real{p | abs(p) <= POWER_MAX},
    headroom_up:   Real{h | 0.0 <= h && h <= POWER_MAX},
    headroom_down: Real{h | 0.0 <= h && h <= POWER_MAX},
) -> EmulatedPower
    where chain_order <= 0
{
    clamp(desired_power, -headroom_down, headroom_up)
}
