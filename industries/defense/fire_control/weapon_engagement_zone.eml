// weapon_engagement_zone.eml -- WEZ inner / outer boundary
// kinematics.
//
// The Weapon Engagement Zone (WEZ) is the region within which a
// guided-weapon launch has a non-zero probability of intercept.
// EML's scalar surface ships the closed-form scalar boundaries:
//
//   r_outer = v_w * t_max - v_t * t_max * cos(angle_off)
//   r_inner = max(0, r_min_safe)
//
// where v_w is the weapon mean speed, v_t is the target speed,
// t_max is the burn / battery duration, and angle_off is the
// target's aspect angle from the launch line.
//
// Companion of proportional_navigation.eml + ballistic_trajectory.
// MIL-STD-882 Class B (incorrect WEZ produces fratricide /
// collateral risk).
//
// Chain order 1 (single cos).

module weapon_engagement_zone;

const V_MAX:        Real = 5.0e3
const T_MAX:        Real = 600.0       // 10 minute weapon
const RANGE_MAX:    Real = 5.0e5
const ANGLE_MAX:    Real = 3.1416

type EngagementRange = Real where chain_order <= 1

@target(fpga, clock_mhz = 200, precision = float32)
@verify(lean, theorem = "outer_wez_decreases_with_target_speed_aligned")
fn outer_wez_range(
    weapon_speed: Real{v | 0.0 <= v && v <= V_MAX},
    target_speed: Real{v | 0.0 <= v && v <= V_MAX},
    burn_time:    Real{t | 0.0 <= t && t <= T_MAX},
    aspect_angle: Real{a | abs(a) <= ANGLE_MAX},
) -> EngagementRange
    where chain_order <= 1
{
    let nominal = weapon_speed * burn_time;
    let target_advance = target_speed * burn_time * cos(aspect_angle);
    clamp(nominal - target_advance, 0.0, RANGE_MAX)
}

// Inner WEZ -- typically a fixed safety arming distance.
@target(fpga, clock_mhz = 500, precision = float32)
@verify(lean, theorem = "inner_wez_nonneg")
fn inner_wez_range(
    safe_arming_distance: Real{d | 0.0 <= d && d <= RANGE_MAX},
) -> EngagementRange
    where chain_order <= 0
{
    safe_arming_distance
}

// Time-of-flight estimate: range / closing-speed approximation.
// The host iterates this as the launch-decision sanity check.
@target(fpga, clock_mhz = 250, precision = float32)
@verify(lean, theorem = "tof_inverse_proportional_to_closing")
fn time_of_flight(
    range_m:      Real{r | 0.0 <= r && r <= RANGE_MAX},
    weapon_speed: Real{v | 0.0 <  v && v <= V_MAX},
    target_speed: Real{v | 0.0 <= v && v <= V_MAX},
    aspect_angle: Real{a | abs(a) <= ANGLE_MAX},
) -> Real
    where chain_order <= 1
{
    let closing = weapon_speed - target_speed * cos(aspect_angle);
    range_m / clamp(closing, 1.0, V_MAX)
}
