-- Precision-bound theorem template (DO-178C verification evidence).
--
-- Use case: prove that a function's output is within `eps` of its
-- ideal mathematical value over a declared input domain.
--
-- Jinja variables:
--   {{ theorem_name }}    -- name from @verify(theorem = ...)
--   {{ fn_name }}         -- the EML-lang function being verified
--   {{ params }}          -- parameter list as Lean binders
--                            e.g. "(x : Real) (y : Real)"
--   {{ domain }}          -- precondition expression
--                            e.g. "0 < x ∧ x < 1"
--   {{ ideal_expr }}      -- the closed-form ideal the impl approximates
--                            e.g. "Real.sin x"
--   {{ eps }}             -- precision tolerance
--                            e.g. "1.0e-12"
--
-- The template body emits a `sorry` placeholder; humans fill in
-- the precision proof for cert submission.

import MachLib.EML
import MachLib.Trig

open MachLib
open MachLib.Real

theorem {{ theorem_name }} {{ params }}
    (h : {{ domain }}) :
    abs ({{ fn_name }} {{ params_pos }} - {{ ideal_expr }}) <= {{ eps }} := by
  unfold {{ fn_name }}
  sorry  -- TODO: prove the precision bound against MachLib foundations
