// baro_altitude.eml -- barometric altitude from static pressure.
//
// The international standard atmosphere (ISA) altitude formula
// in the troposphere (h <= 11 km):
//
//   h = (T0 / L) * (1 - (P / P0) ^ (R*L/g))
//
// where:
//   P0  = 101325 Pa     sea-level reference pressure
//   T0  = 288.15 K      sea-level reference temperature
//   L   = 0.0065 K/m    standard tropospheric lapse rate
//   R   = 287.058 J/(kg*K) gas constant for dry air
//   g   = 9.80665 m/s^2  standard gravity
//
// Chain order = 1 (single pow). This is the kernel inside every
// pitot-static air-data computer; modern GA / Part 23 avionics
// integrate it with GPS for terrain-clearance computations.

module baro_altitude;

const P0:        Real = 101325.0
const T0:        Real = 288.15
const LAPSE:     Real = 0.0065
const RL_OVER_G: Real = 0.190263                   // R * L / g
const T0_OVER_L: Real = 44330.769230769            // T0 / L
const P_MIN:     Real = 22632.0                    // tropopause floor
const P_MAX:     Real = 110000.0                   // sea-level + buffer

type Altitude = Real where chain_order <= 1

@target(fpga, clock_mhz = 100, precision = float64)
@verify(lean, theorem = "baro_altitude_monotone_decreasing_in_pressure")
fn pressure_to_altitude(static_pressure: Real{p | P_MIN <= p && p <= P_MAX}) -> Altitude
    where chain_order <= 1
{
    T0_OVER_L * (1.0 - pow(static_pressure / P0, RL_OVER_G))
}

// Inverse: altitude -> pressure (used in test harnesses + the
// reciprocal direction of the tracking loop).
//   P = P0 * (1 - L * h / T0) ^ (g / (R*L))
@target(fpga, clock_mhz = 100, precision = float64)
@verify(lean, theorem = "altitude_to_pressure_inverse")
fn altitude_to_pressure(altitude: Real{h | -500.0 <= h && h <= 11000.0}) -> Real
    where chain_order <= 1
    ensures  (result >= P_MIN)
    ensures  (result <= P_MAX)
{
    P0 * pow(1.0 - LAPSE * altitude / T0, 5.25588)
}

// QFE-corrected altitude -- pressure altitude minus the field
// elevation, the form a tower-set altimeter reads. Chain order
// 1 (inherits from pressure_to_altitude) but the post-subtract
// is chain-0.
@target(fpga, clock_mhz = 100, precision = float64)
fn qfe_altitude(
    static_pressure: Real{p | P_MIN <= p && p <= P_MAX},
    field_pressure:  Real{p | P_MIN <= p && p <= P_MAX},
) -> Altitude
    where chain_order <= 1
{
    let pa = T0_OVER_L * (1.0 - pow(static_pressure / P0, RL_OVER_G));
    let pf = T0_OVER_L * (1.0 - pow(field_pressure / P0, RL_OVER_G));
    pa - pf
}
