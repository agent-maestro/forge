// imu_complementary_filter.eml -- IMU attitude estimator.
//
// The classical Wahba-light fusion: the gyro integrates angular
// rate (low drift over short windows but accumulates bias), the
// accelerometer measures the gravity vector (no drift but noisy
// and corrupted by linear acceleration). A complementary filter
// blends the two:
//
//   pitch[k+1] = alpha * (pitch[k] + gyro_y * dt) + (1 - alpha) * accel_pitch
//
// alpha is typically 0.98 -- 98 % gyro short-term, 2 % accel
// long-term. atan2 over the accel components recovers pitch
// independent of bank angle. Chain order 1 (single atan2).
//
// This is the kernel inside every consumer drone autopilot's
// attitude loop. Same .eml compiles to the C reference (host
// validation), Verilog (FPGA flight controller), and Lean
// (DO-178C Tool Qualification Level B argument).

module imu_complementary_filter;

const ALPHA_DEFAULT: Real = 0.98
const G_REF:         Real = 9.80665
const DT_MAX:        Real = 0.1
const RATE_MAX:      Real = 35.0           // 35 rad/s -- well past tumble

type AttitudeAngle = Real where chain_order <= 1

@target(fpga, clock_mhz = 200, precision = float32)
@verify(lean, theorem = "complementary_filter_bounded_drift")
fn pitch_update(
    pitch_prev: Real{p | abs(p) <= 3.1416},
    gyro_y:     Real{g | abs(g) <= RATE_MAX},
    accel_x:    Real{a | abs(a) <= 16.0 * G_REF},
    accel_z:    Real{a | abs(a) <= 16.0 * G_REF},
    dt:         Real{t | 0.0 < t && t <= DT_MAX},
    alpha:      Real{a | 0.0 <= a && a <= 1.0},
) -> AttitudeAngle
    where chain_order <= 1
{
    let gyro_step = pitch_prev + gyro_y * dt;
    let accel_pitch = atan2(accel_x, accel_z);
    alpha * gyro_step + (1.0 - alpha) * accel_pitch
}

// Roll equivalent. Same structure as pitch_update; uses
// gyro_x and the (accel_y, accel_z) axes.
@target(fpga, clock_mhz = 200, precision = float32)
@verify(lean, theorem = "complementary_filter_roll_bounded_drift")
fn roll_update(
    roll_prev: Real{r | abs(r) <= 3.1416},
    gyro_x:    Real{g | abs(g) <= RATE_MAX},
    accel_y:   Real{a | abs(a) <= 16.0 * G_REF},
    accel_z:   Real{a | abs(a) <= 16.0 * G_REF},
    dt:        Real{t | 0.0 < t && t <= DT_MAX},
    alpha:     Real{a | 0.0 <= a && a <= 1.0},
) -> AttitudeAngle
    where chain_order <= 1
{
    let gyro_step = roll_prev + gyro_x * dt;
    let accel_roll = atan2(accel_y, accel_z);
    alpha * gyro_step + (1.0 - alpha) * accel_roll
}

// Gravity-vector magnitude check. The accelerometer-derived
// pitch term is only trustworthy when |a| ≈ g; outside that
// window (during a coordinated turn or hard manoeuvre) the
// filter should drop alpha toward 1 to ride on gyro alone.
// This gate returns the gain-modulation factor in [0, 1].
@target(fpga, clock_mhz = 300, precision = float32)
fn accel_trust(accel_mag: Real{a | 0.0 <= a && a <= 16.0 * G_REF}) -> Real
    where chain_order <= 0
    ensures  (result >= 0.0)
    ensures  (result <= 1.0)
{
    let dev = abs(accel_mag - G_REF);
    1.0 - clamp(dev / G_REF, 0.0, 1.0)
}
