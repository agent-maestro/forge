// expected_shortfall.eml -- Expected Shortfall (ES / CVaR).
//
// Expected Shortfall is the average loss conditional on being
// in the tail beyond the VaR percentile. For a normal return
// distribution at confidence alpha:
//
//   ES(alpha) = mu - sigma * phi(z_alpha) / (1 - alpha)
//
// where z_alpha is the alpha-quantile of N(0,1) and phi is its
// PDF. The host supplies (z_alpha, phi(z_alpha)) precomputed;
// this gate is the closed-form ES.
//
// FRTB requires ES (not VaR) for trading-book capital under
// Basel III. Companion of var_monte_carlo.eml in the
// finance/risk subfolder.
//
// Chain order 0 (no transcendentals -- the phi value is
// supplied as input).

module expected_shortfall;

const SIGMA_MIN:    Real = 1.0e-9
const SIGMA_MAX:    Real = 1.0e3
const ALPHA_MIN:    Real = 0.5
const ALPHA_MAX:    Real = 0.99999
const PHI_MAX:      Real = 0.5
const HORIZON_MAX:  Real = 1000.0

type RiskSignal = Real where chain_order <= 0

@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "es_increases_with_sigma")
fn parametric_es(
    mean_return:  Real{m | abs(m) <= 1.0},
    stdev_return: Real{s | SIGMA_MIN <= s && s <= SIGMA_MAX},
    horizon_days: Real{h | 1.0 <= h && h <= HORIZON_MAX},
    z_alpha:      Real{z | 0.0 <= z && z <= 5.0},
    phi_at_z:     Real{p | 0.0 <= p && p <= PHI_MAX},
    alpha:        Real{a | ALPHA_MIN <= a && a <= ALPHA_MAX},
) -> RiskSignal
    where chain_order <= 0
{
    let scale = stdev_return * phi_at_z / (1.0 - alpha);
    -mean_return * horizon_days + scale * horizon_days
}

// Monte-Carlo running tail-mean: given the running tail-loss
// sum and tail count, returns the realised ES estimate.
@target(fpga, clock_mhz = 500, precision = float64)
@verify(lean, theorem = "mc_es_zero_at_zero_count")
fn mc_es_estimate(
    tail_loss_sum: Real{x | 0.0 <= x && x <= 1.0e12},
    tail_count:    Real{n | 1.0 <= n && n <= 1.0e9},
) -> RiskSignal
    where chain_order <= 0
    ensures  (result >= 0.0)
{
    tail_loss_sum / tail_count
}

// Tail-loss accumulator gate: given the previous running sum
// and a new path loss, returns the updated sum if the loss
// exceeds the tail threshold (otherwise unchanged). Used in
// the MC estimator's tail aggregation.
@target(fpga, clock_mhz = 500, precision = float64)
fn tail_loss_accumulator(
    prev_sum:       Real{x | 0.0 <= x && x <= 1.0e12},
    path_loss:      Real{x | 0.0 <= x && x <= 1.0e9},
    tail_threshold: Real{x | 0.0 <= x && x <= 1.0e9},
) -> Real
    where chain_order <= 0
{
    let excess = clamp(path_loss - tail_threshold, 0.0, 1.0e9);
    prev_sum + clamp(excess / 0.001, 0.0, 1.0) * path_loss
}
