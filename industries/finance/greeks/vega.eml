// vega.eml -- Black-Scholes vega. Vega is the first derivative of
// option price with respect to volatility (sigma). Same for calls
// and puts.
//
//   vega = S * phi(d1) * sqrt(T)
//
// where phi(x) is the standard normal PDF. Chain order 2.

module vega;

const HALF:           Real = 0.5
const SQRT_2_PI_INV:  Real = 0.3989422804014327
const TINY_T:         Real = 0.000274

type GreekSignal = Real where chain_order <= 3

fn norm_pdf(x: Real) -> Real
    where chain_order <= 1
{
    SQRT_2_PI_INV * exp(-HALF * x * x)
}

fn d1(spot: Real, strike: Real, rate: Real, vol: Real, time_to_expiry: Real)
    -> Real
    where chain_order <= 2
{
    let drift_term    = (rate + HALF * vol * vol) * time_to_expiry;
    let log_moneyness = ln(spot / strike);
    let vol_sqrt_t    = vol * sqrt(time_to_expiry);
    (log_moneyness + drift_term) / vol_sqrt_t
}

@target(fpga, clock_mhz = 250, precision = float64)
@verify(lean, theorem = "bs_vega_non_negative")
fn bs_vega(
    spot:           Real{s | s > 0.0},
    strike:         Real{k | k > 0.0},
    rate:           Real,
    vol:            Real{v | v > 0.0},
    time_to_expiry: Real{t | t > TINY_T},
) -> GreekSignal
    ensures  (result >= 0.0)
{
    let d1_val = d1(spot, strike, rate, vol, time_to_expiry);
    spot * norm_pdf(d1_val) * sqrt(time_to_expiry)
}
