// stdlib/ml -- neural-network activation primitives.
//
// Split out of stdlib::math as of 2026-04 so ML code can write
// `use stdlib::ml;` and discover sigmoid / softplus / relu /
// leaky_relu / gelu / swish without pulling in the rest of math.
//
// Domain bounds + chain orders match the original definitions.
// Every function is pure (no state, no I/O) -- safe for
// @target(fpga, ...) blocks.

module ml;

// ── Sigmoid family (chain order 1) ───────────────────────────

// Standard logistic sigmoid. SuperBEST will recognise the
// alternative `tanh(x/2)/2 + 1/2` form and rewrite it to this
// one; calling sigmoid() directly avoids the rewrite cost.
fn sigmoid(x: f64) -> f64
    where chain_order <= 1
{
    1.0 / (1.0 + exp(-x))
}

// Alternative tanh-based sigmoid form. Mathematically identical
// to `sigmoid(x)` but written using the BERT/GPT-paper identity
//
//     sigmoid(x) = tanh(x/2) / 2 + 1/2
//
// SuperBEST recognises this exact pattern and rewrites it to
// the canonical sigmoid form before any backend emits code,
// saving ~1.08 decimal digits of precision per evaluation.
//
// Use this when porting code that prefers the tanh-symmetric
// formulation; let SuperBEST canonicalise it for you instead
// of hand-rewriting at every site.
fn sigmoid_alt(x: f64) -> f64
    where chain_order <= 2
{
    tanh(x / 2.0) / 2.0 + 0.5
}

// softplus(x) = ln(1 + exp(x)). Chain order 2 because ln
// composes through exp -- a more numerically-stable smooth
// ReLU, costing one extra chain step.
fn softplus(x: f64) -> f64
    where chain_order <= 2
{
    ln(1.0 + exp(x))
}

// Swish / SiLU: x * sigmoid(x). Smoother than ReLU + retains
// gradient signal at large negative inputs.
fn swish(x: f64) -> f64
    where chain_order <= 1
{
    x / (1.0 + exp(-x))
}

// GELU (Gaussian-error-linear-unit), tanh-based approximation
// from the BERT / GPT papers. Chain order 1 because there's a
// single tanh call (the polynomial inside is chain-0).
fn gelu(x: f64) -> f64
    where chain_order <= 1
{
    0.5 * x * (1.0 + tanh(0.7978845608 * (x + 0.044715 * x * x * x)))
}

// ── ReLU family (chain order 0 -- clamp is non-transcendental) ──

fn relu(x: f64) -> f64
    where chain_order <= 0
{
    clamp(x, 0.0, 1.0e30)
}

// Leaky ReLU. Slope below zero is `alpha`, typically 0.01.
fn leaky_relu(x: f64, alpha: f64) -> f64
    where chain_order <= 0
{
    clamp(x, alpha * x, 1.0e30)
}

// ── Exponential ReLU family (chain order 1) ──────────────────

// ELU (Exponential Linear Unit). Smooths the ReLU kink with an
// exponential tail below zero -- mean activation closer to zero
// reduces internal covariate shift. `alpha` is the saturation
// magnitude (typically 1.0).
//
// Chain order 1: a single exp call.
fn elu(x: f64, alpha: f64) -> f64
    where chain_order <= 1
{
    clamp(x, 0.0, 1.0e30) + clamp(alpha * (exp(clamp(x, -1.0e30, 0.0)) - 1.0), -1.0e30, 0.0)
}

// SELU (Scaled ELU). Self-normalizing -- the fixed-point
// (alpha, scale) constants are chosen so a deep stack of
// SELU-activated linear layers preserves zero mean / unit
// variance. Chain order 1.
fn selu(x: f64) -> f64
    where chain_order <= 1
{
    1.0507009873554805 * elu(x, 1.6732632423543772)
}

// Mish (Misra 2019). Smooth, non-monotonic, self-gated --
// outperforms swish / GELU on some vision benchmarks.
// `mish(x) = x * tanh(softplus(x))`. Chain order 2 (tanh
// composes through ln+exp via softplus).
fn mish(x: f64) -> f64
    where chain_order <= 2
{
    x * tanh(ln(1.0 + exp(x)))
}

// ── Hard / linear approximations (chain order 0) ─────────────

// Hard sigmoid. Piecewise-linear approximation to sigmoid;
// clamps to [0, 1] with linear midband. Cheap on FPGA / int8.
fn hard_sigmoid(x: f64) -> f64
    where chain_order <= 0
{
    clamp(0.2 * x + 0.5, 0.0, 1.0)
}

// Hard tanh. Piecewise-linear approximation to tanh; clamps
// to [-1, 1]. Same FPGA-friendly profile as hard_sigmoid.
fn hard_tanh(x: f64) -> f64
    where chain_order <= 0
{
    clamp(x, -1.0, 1.0)
}

// Hard swish. Piecewise approximation to swish for mobile
// inference. `x * relu6(x+3) / 6` -- written here using
// clamp since EML doesn't expose a relu6 builtin.
fn hard_swish(x: f64) -> f64
    where chain_order <= 0
{
    x * clamp(x + 3.0, 0.0, 6.0) / 6.0
}
