module control;

// Plain PID controller. Chain order 0.
fn pid(error: f64, integral: f64, derivative: f64,
       Kp: f64, Ki: f64, Kd: f64) -> f64
  where chain_order <= 0
{
    Kp * error + Ki * integral + Kd * derivative
}

